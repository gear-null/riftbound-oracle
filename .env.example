# Google Drive upload — OAuth2 credentials
# Create at: https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID (Desktop app)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Drive folder ID (from the folder URL: drive.google.com/drive/folders/<this-id>)
DRIVE_FOLDER_ID=

# Riftcodex API base URL
RIFTCODEX_API_URL=https://api.riftcodex.com
